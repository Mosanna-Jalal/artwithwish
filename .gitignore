# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 3D models: the converted .glb are committed so they deploy to Vercel.
# Ignore only oversized raw source files (e.g. the 28MB header) — those are
# served from Google Drive via /api/hero-model instead.
/public/models/header.glb
/public/models/*.gltf

# fetched Instagram profile data (re-fetch with curl when importing)
/scripts/ig-data.json
